local.file_match "backend_logs" {
  path_targets = [
    {
      __path__ = "/logs/*.log",
      job = "backend",
      service = "backend",
      environment = "local",
    },
  ]
}

loki.source.file "backend" {
  targets    = local.file_match.backend_logs.targets
  forward_to = [loki.write.local.receiver]
}

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}